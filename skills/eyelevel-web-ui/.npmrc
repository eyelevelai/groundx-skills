# Allow installs to proceed even when peer-dep ranges don't perfectly line up.
#
# Why: this skill's deps (MUI, React, TypeScript, Vitest, Testing Library)
# are all current. Replit, Cowork, and other dev environments often layer
# their own globally-installed typescript-eslint / eslint configs on top,
# which sometimes pin older TypeScript / React peer ranges. Strict peer-dep
# resolution then fails with a confusing error (npm <= 11.6 also has a known
# `isDescendantOf` resolver bug that surfaces under those exact conditions).
#
# `legacy-peer-deps=true` tells npm to fall back to its pre-v7 behavior:
# install what package.json says, surface mismatches as warnings, don't
# refuse the install. This is the standard escape hatch for the React/MUI
# ecosystem and is what most large React projects ship.
legacy-peer-deps=true
